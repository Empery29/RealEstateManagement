@model RealEstateManagement.Models.MaintenanceRequest

@{
    ViewData["Title"] = "New Maintenance Ticket";
}

<h1>New Maintenance Request</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label asp-for="Issue" class="control-label"></label>
                <textarea asp-for="Issue" class="form-control"></textarea>
            </div>
            <div class="form-group mb-3">
                <label asp-for="PropertyId" class="control-label">Property ID</label>
                <input asp-for="PropertyId" class="form-control" />
            </div>
            <div class="form-group">
                <input type="submit" value="Submit Ticket" class="btn btn-warning" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>