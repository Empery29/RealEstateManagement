@model RealEstateManagement.Models.Tenant

@{
    ViewData["Title"] = "New Maintenance Ticket";
}

<h1>New Maintenance Request</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" asp-controller="Maintenance">
            <input value="@Model.Id" name="TenantId" class="form-control" hidden/>
            <div class="form-group mb-3">
                <label class="control-label"></label>
                <input name="Title" class="form-control" placeholder="Title"></input>
            </div>
            <div class="form-group mb-3">
                <label   class="control-label"></label>
                <textarea name="Issue" class="form-control" placeholder="Issue"></textarea>
            </div>
            <div class="form-group">
                <input type="submit" value="Submit Request" class="btn btn-warning" />
            </div>
        </form>
    </div>
</div>