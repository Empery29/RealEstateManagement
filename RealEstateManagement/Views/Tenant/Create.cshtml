@model RealEstateManagement.Models.Tenant

@{
    ViewData["Title"] = "Register New Tenant";
}

<h1>Register Tenant</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label asp-for="FullName" class="control-label"></label>
                <input asp-for="FullName" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Gender" class="control-label"></label>
                <input asp-for="Gender" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Phone" class="control-label"></label>
                <input asp-for="Phone" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label"></label>
                <input type="email" asp-for="Email" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="MoveInDate" class="control-label"></label>
                <input asp-for="MoveInDate" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="NumberOfYear" class="control-label">NumberOfYear</label>
                <input type="number" asp-for="NumberOfYear" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="PropertyId" class="control-label">Property ID</label>
                <input asp-for="PropertyId" class="form-control" />
            </div>
            <div class="form-group">
                <input type="submit" value="Register" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>