@using RealEstateManagement.Models.DTO
@model TenantDashboardViewModel

@{
    ViewBag.Title = "Tenant Dashboard";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Welcome, @Model.CurrentTenant.FullName 👋</h2>
        <span class="badge bg-info text-dark">
            Lease:@Model.CurrentTenant.MoveInDate.ToShortDateString() - @(Model.CurrentTenant.ExpiryDate != null ? Model.CurrentTenant.ExpiryDate!.Value : "NOT PROVIDED")
        </span>
    </div>

    <!-- RENT STATUS -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Rent Status</h5>

            <p>
                 <strong>Amount Due:</strong> ₦@Model.CurrentTenant.Property.price.ToString("N0") 
            </p>

            <p>
                <strong>Due Date:</strong> @(Model.CurrentTenant.ExpiryDate != null ? Model.CurrentTenant.ExpiryDate!.Value.ToShortDateString() : "NOT PROVIDED")
            </p>

            <p>
                <strong>Status:</strong>
                 @if (Model.CurrentTenant.Property.price > 0)
                { 
                    <span class="badge bg-success">Paid</span>
                 } 
                 else if (DateTime.Now > Model.CurrentTenant.ExpiryDate!.Value.Date)
                {
                    <span class="badge bg-danger">Overdue</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                } 
            </p>

            <a href="/Payments/Pay" class="btn btn-primary">Pay Rent</a>
        </div>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="row mb-4">
        <div class="col-md-4">
            <a asp-action="Create" asp-controller="Maintenance" asp-route-tenantId="@Model.CurrentTenant.Id" class="btn btn-outline-dark w-100 p-3">
                🛠️ Report Issue
            </a>
        </div>

        <div class="col-md-4">
            <a href="/Payments/History" class="btn btn-outline-dark w-100 p-3">
                💳 Payment History
            </a>
        </div>

       @*  <div class="col-md-4">
            <a href="/Lease/Details" class="btn btn-outline-dark w-100 p-3">
                📄 View Lease
            </a>
        </div> *@
    </div>

    <!-- BILLS -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Utility Bills</h5>

           @if (Model.PastTenants.Any())
            { 
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Due Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var x in Model.PastTenants)
                        {
                            <tr>
                                <td> @x.Property.Title</td>
                                <td>@x.Property.price</td>
                                <td>
                                     @if (x.Property.price > 0)
                                    { 
                                        <span class="badge bg-success">Paid</span>
                                    
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    } 
                                </td>
                                <td> @(x.ExpiryDate != null ? x.ExpiryDate!.Value.ToShortDateString() : "NOT PROVIDED")</td>
                            </tr>
                      } 
                    </tbody>
                </table>
             }
            else
            {
                <p>No bills available.</p>
            } 
        </div>
    </div>

    <!-- MAINTENANCE -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Recent Maintenance Requests</h5>

             @if (Model.MaintenanceRequests.Any())
            { 
                <ul class="list-group">
                     @foreach (var req in Model.MaintenanceRequests)
                    { 
                        <li class="list-group-item d-flex justify-content-between">
                            <span> @req.PropertyTitle</span>
                            <span class="badge bg-secondary">@req.Status</span>
                        </li>
                    } 
                </ul>
             }
            else
            {
                <p>No maintenance requests yet.</p>
            } 
        </div>
    </div>

</div>
