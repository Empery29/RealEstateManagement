@model IEnumerable<RealEstateManagement.Models.Land>

@{
    ViewData["Title"] = "Land List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Land Records</h2>
        <a asp-action="Create" class="btn btn-primary">Add New Land</a>
    </div>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Address</th>
                <th>Survey Number</th>
                <th>Size (sqm)</th>
                <th>City</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Address</td>
                    <td>@item.SurveyNumber</td>
                    <td>@item.SizeSquareMeters</td>
                    <td>@item.City</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
