@model RealEstateManagement.Models.Land

@{
    ViewData["Title"] = "Land Details";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h2 class="mb-0">Property Details</h2>
            <span class="badge bg-light text-primary">ID: @Model.Id</span>
        </div>
        <div class="card-body">
            <h4 class="text-muted mb-4">@Model.Title</h4>

            <div class="row mb-3">
                <div class="col-sm-3 fw-bold">Address:</div>
                <div class="col-sm-9">@Model.Address</div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-3 fw-bold">City:</div>
                <div class="col-sm-9">@Model.City</div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-3 fw-bold">Survey Number:</div>
                <div class="col-sm-9">
                    <code class="text-dark">@Model.SurveyNumber</code>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-3 fw-bold">Land Size:</div>
                <div class="col-sm-9">
                    @Model.SizeSquareMeters sqm
                    <small class="text-muted ml-2">
                        (@(Model.SizeSquareMeters >= 600 ? "Approx. " + Math.Round(Model.SizeSquareMeters / 600, 2) + " Plot(s)" : "Less than a full plot"))
                    </small>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light">
            <div class="btn-group">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit Property</a>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>