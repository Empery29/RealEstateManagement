@model Property

<h2>Add Property</h2>

<form asp-action="Create">

    <div class="form-group">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label>Address</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="form-group">
        <label>Price</label>
        <input asp-for="price" class="form-control" />
    </div>

    <div class="form-group">
        <label>Bedrooms</label>
        <input asp-for="Bedrooms" class="form-control" />
    </div>
    <div class="form-group">
        <label>Is For Sale</label>
        <select asp-for="IsForSale" class="form-control">
            <option value ="True">True</option>
            <option value="False">False</option>
        </select>
    </div>

    <div class="form-group">
        <label>Is Flat</label>
        <select asp-for="IsFlat" class="form-control">
            <option value="True">True</option>
            <option value="False">False</option>
        </select>
    </div>


    <div class="form-group">
        <label asp-for="ImageUrl" class="control-label">Upload Property Image Link</label>
        <input name="imageFile" type="text" class="form-control" />
    </div>


    <button class="btn btn-success">Save</button>

</form>